# =====================================================================================
# CONFIGURATION DE L'IA
# =====================================================================================
# Clé API pour accéder au service cloud hébergeant Qwen 2.5/3 (Ollama Cloud, Groq, etc.)
OLLAMA_API_KEY=ollama_api.key

# =====================================================================================
# CONFIGURATION DE LA BASE DE DONNÉES (POSTGRESQL)
# =====================================================================================
# Identifiants administrateur pour la création de la base de données
POSTGRES_USER=artefact_user
POSTGRES_PASSWORD=artefact_password
POSTGRES_DB=elections_db

# Chaine de connexion pour le pipeline d'ingestion (Accès en écriture / DDL complet)
# Format : postgresql://user:password@host:port/dbname
# Remarque : Utiliser le host 'db' (port 5432) dans Docker, ou 'localhost' (port 5433) pour un test local.
DATABASE_URL=postgresql://artefact_user:artefact_password@localhost:5433/elections_db

# Chaine de connexion sécurisée pour l'Agent IA (Accès en lecture seule strictement)
# L'utilisateur 'artefact_reader' est créé automatiquement par le script 'init_views.sql'.
AGENT_DB_URL=postgresql://artefact_reader:reader_password@localhost:5433/elections_db

# =====================================================================================
# CONFIGURATION DES OUTILS D'OBSERVABILITÉ (PGADMIN)
# =====================================================================================
# Identifiants pour accéder à l'interface graphique de la base de données (http://localhost:8080)
PGADMIN_DEFAULT_EMAIL=admin@artefact.com
PGADMIN_DEFAULT_PASSWORD=admin_password