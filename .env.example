# Configuration des API

# Clé API Ollama (pour les LLM)
OLLAMA_API_KEY=votre_cle_ollama

# Clé API Gemini (pour les embeddings RAG)
GEMINI_API_KEY=votre_cle_gemini


# Configuration PostgreSQL (admin)
POSTGRES_USER=artefact_user
POSTGRES_PASSWORD=artefact_password
POSTGRES_DB=elections_db

# URL pour l'ingestion (accès écriture)
# NOTE: Pour Docker, utilisez @db:5432. Le port 5433 est pour l'hôte local uniquement.
DATABASE_URL=postgresql://artefact_user:artefact_password@db:5432/elections_db

# URL pour l'agent (accès lecture seule)
# NOTE: Pour Docker, utilisez @db:5432. Le port 5433 est pour l'hôte local uniquement.
# L'agent utilise artefact_reader (lecture seule), pas artefact_user (écriture)
AGENT_DB_URL=postgresql://artefact_reader:reader_password@db:5432/elections_db


# Configuration pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@artefact.com
PGADMIN_DEFAULT_PASSWORD=admin
